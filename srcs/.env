# DOMAIN - Domain name your stack will use (e.g., for Nginx server_name and WordPress URLs)
# The actual domain value (localhost = access only from your machine)
DOMAIN_NAME=localhost             

# HOST VOLUMES (WSL/Linux) - Host filesystem paths where persistent data will be stored (bind mounts / volume backing dirs)
# Host directory that will persist MariaDB database files
MARIADB_DATA_DIR=/home/$USER/data/mariadb      
# Host directory that will persist WordPress files (wp-content, uploads, etc.)
WORDPRESS_DATA_DIR=/home/$USER/data/wordpress  

# MARIADB - Environment variables used to initialize/configure the MariaDB container
# Database name to create/use for WordPress
MARIADB_DATABASE=wordpress        
# Non-root database user that WordPress will use to connect
MARIADB_USER=wp_user              
# Password for the WordPress DB user (must be changed)
MARIADB_PASSWORD=CHANGE_ME_MARIADB_PASSWORD      
# MariaDB root password (admin/superuser; must be changed)
MARIADB_ROOT_PASSWORD=CHANGE_ME_MARIADB_ROOT_PASSWORD  

# WORDPRESS - Values used during WordPress installation/bootstrap (site + users)
# WordPress site title shown in the admin and in the site metadata
WP_TITLE=inception                
# WordPress administrator username to be created
WP_ADMIN_USER=wp_admin            
# Password for the WordPress admin user (must be changed)
WP_ADMIN_PASSWORD=CHANGE_ME_WP_ADMIN_PASSWORD    
# Email address for the WordPress admin user
WP_ADMIN_EMAIL=wp_admin@example.com

# Additional (non-admin) WordPress user to be created
WP_USER=wp_user1                  
# Password for the additional WordPress user (must be changed)
WP_USER_PASSWORD=CHANGE_ME_WP_USER_PASSWORD      
# Email address for the additional WordPress user
WP_USER_EMAIL=wp_user1@example.com 