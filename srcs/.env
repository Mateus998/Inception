# .env
# Non-secret configuration only (secrets go in ./secrets/*.txt)
# Keep it simple and explicit.

# Domain required by the subject
WP_DOMAIN=mateferr.42.fr

# WordPress site info
WP_TITLE=Inception

# IMPORTANT (subject rule): admin username must NOT contain "admin", "Admin", "administrator", etc.
# Choose something like "mateferr42" or "wpowner".
WP_ADMIN_USER=mateferr42
WP_ADMIN_EMAIL=mateferr42@example.com

# Optional extra user (non-admin)
WP_USER=mateferr_user
WP_USER_EMAIL=mateferr_user@example.com

# Database settings
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser